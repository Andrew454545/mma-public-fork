{
	"compilerOptions": {
		"target": "es2023",
		"lib": ["ES2023", "DOM"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node", "@wdio/globals/types", "@types/mocha"],
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"strict": true,
		"paths": { "@/*": ["../src/*"] }
	},
	"include": ["e2e/**/*.ts"]
}
